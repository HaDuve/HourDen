{
  "name": "@hourden/domain",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./invoice-pdf": {
      "types": "./src/invoice-pdf.ts",
      "development": "./src/invoice-pdf.ts",
      "default": "./dist/invoice-pdf.js"
    },
    "./invoice-pdf-snapshot": {
      "types": "./src/invoice-pdf-snapshot.ts",
      "development": "./src/invoice-pdf-snapshot.ts",
      "default": "./dist/invoice-pdf-snapshot.js"
    },
    "./invoice-issuance-snapshot": {
      "types": "./src/invoice-issuance-snapshot.ts",
      "development": "./src/invoice-issuance-snapshot.ts",
      "default": "./dist/invoice-issuance-snapshot.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.6",
    "pdf-parse": "^2.4.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "pdfkit": "^0.19.1"
  }
}
