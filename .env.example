# Copy to .env and fill in secrets (file is gitignored)

# --- Local API (docker compose Postgres on host 5433) ---
DATABASE_URL=postgresql://hourden:hourden@localhost:5433/hourden
PORT=3001

# Optional API key when hitting :3001 directly (empty = open; scripts/CI only)
HOURDEN_API_KEY=

# Operator login (migration creates User from these; required on first migrate after auth slice)
HOURDEN_OPERATOR_PASSWORD=

# Clockify CSV export padding (User / Email columns)
HOURDEN_OPERATOR_NAME="Hannes Duve"
HOURDEN_OPERATOR_EMAIL=hannes.duve@outlook.com

# Operator calendar for Report grouping and Clockify CSV dates (IANA time zone)
HOURDEN_TIMEZONE=Europe/Berlin

# --- Deploy (scripts/deploy-remote.sh) ---
SSH_TARGET=root@YOUR_IP
REMOTE_DIR=/opt/HourDen
REMOTE_WEB_DIR=/var/www/hourden

# --- Production verify (scripts/verify-production.sh) ---
HOURDEN_BASE_URL=https://hourden.hannesduve.com
# Uses HOURDEN_OPERATOR_EMAIL and HOURDEN_OPERATOR_PASSWORD above
