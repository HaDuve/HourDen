{
  "name": "hourden",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @hourden/domain && npm run build -w @hourden/api && npm run build -w @hourden/web",
    "test": "vitest run",
    "verify:build": "node scripts/verify-built-api.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:api": "npm run dev -w @hourden/api",
    "dev:web": "npm run dev -w @hourden/web"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
